# Copy to /etc/perfinpy/perfinpy.env on the Oracle Cloud Ubuntu VM.
# Keep this file private after filling real values.

SECRET_KEY=change-me
DATABASE_URL=sqlite:////opt/perfinpy/accounting.db

# Bind only to the Tailscale interface/IP if you want the app private to tailnet.
# You can also leave BACKEND_HOST/FRONTEND_HOST as 0.0.0.0 and block public ingress
# with Oracle security lists and the VM firewall.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
API_BASE_URL=http://127.0.0.1:8000
GUNICORN_WORKERS=3
