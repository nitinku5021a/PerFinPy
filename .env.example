# Copy to .env and fill in values. Do not commit your real .env.
DATABASE_URL=sqlite:///accounting.db
SECRET_KEY=change-me

# Optional overrides
APP_NAME=Personal Finance Accounting
DEFAULT_CURRENCY=INR

# Production runtime (prod.cmd on Windows, ./prod.sh on Linux/macOS)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
API_BASE_URL=http://127.0.0.1:8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=300

# Excel backup/export
# Leave PERFINPY_EXPORT_URL empty to export from the local database.
# Set it on your Windows machine to the Oracle Cloud Tailscale URL, for example:
# PERFINPY_EXPORT_URL=http://perfinpy-oracle:5173/api/transactions/export?period=all
PERFINPY_BACKUP_DIR=~/PerFinPyBackups
PERFINPY_BACKUP_KEEP_LATEST=5
PERFINPY_EXPORT_URL=
PERFINPY_EXPORT_RETRIES=12
PERFINPY_EXPORT_RETRY_DELAY=10
